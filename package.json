{
  "name": "freshrss-peek",
  "description": "Peek at your unread FreshRSS articles from the toolbar",
  "version": "4.0.0",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/nichochar/FreshRSS-Notify"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx build.ts",
    "build": "cross-env NODE_ENV=\"production\" tsx build.ts",
    "start:firefox": "web-ext run --no-reload -t firefox-desktop",
    "start:chrome": "web-ext run -t chromium",
    "lint:types": "tsc --project tsconfig.json",
    "lint:code": "biome lint",
    "web-ext:build": "npm run build && web-ext build --overwrite-dest"
  },
  "webExt": {
    "sourceDir": "./public/",
    "run": {
      "startUrl": [
        "about:debugging#/runtime/this-firefox"
      ]
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.0",
    "@types/chrome": "0.1.24",
    "cross-env": "10.1.0",
    "esbuild": "0.25.11",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "web-ext": "9.1.0"
  },
  "dependencies": {
    "dompurify": "^3.2.4"
  }
}
